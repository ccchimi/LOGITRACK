# Servidor
PORT=4000

# Datos para ingresar a la base de datos, es necesario si se usa Visual Studio Code con la extensión "PostgreSQL" para poder conectarse a la base de datos y ver las tablas.
# PGHOST=logitrak-db.postgres.database.azure.com
# PGPORT=5432
# PGUSER=ccchimi
# PGPASSWORD=chimicasla8004@
# PGDATABASE=logitrak
# PGSSLMODE=require
# PGSSL_INSECURE=false

PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=tu_password_de_postgres
PGDATABASE=logitrak

# Auth
JWT_SECRET=generar_uno_con__node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_EXPIRA=8h

# RENAPER (Sistema de Identidad Digital). Sin credenciales reales, la
# verificación de identidad corre en modo OFFLINE (lectura del PDF417 del DNI).
RENAPER_API_URL=
RENAPER_API_KEY=

# ---------------------------------------------------------------------------
# Pagos / facturación
# ---------------------------------------------------------------------------
# Mercado Pago y MODO son REALES cuando hay credenciales; sin ellas, el checkout
# por QR cae a un modo sandbox que se aprueba desde la pantalla. La tarjeta
# SIEMPRE es un procesador simulado (no toca ninguna pasarela).

# Mercado Pago (Checkout Pro, SDK oficial `mercadopago`). Con el access token,
# el checkout crea una preferencia real y el cobro lo confirma MP por webhook.
MP_ACCESS_TOKEN=

# MODO (e-commerce, billetera de los bancos). Credenciales de tu comercio.
MODO_API_URL=
MODO_CLIENT_ID=
MODO_CLIENT_SECRET=
# Opcionales: fijan los endpoints/identificadores EXACTOS según tu doc de MODO
# (los valores por defecto son tentativos; ajustá los marcados con [DOC] en
# src/servicios/pagos/modo.js o sobreescribilos acá).
# MODO_TOKEN_URL=
# MODO_INTENTION_URL=
# MODO_STATUS_URL=
# MODO_STORE_ID=

# URL pública del backend, para armar las notification_url de los webhooks de
# MP / MODO. En local con pagos reales, exponé el puerto con ngrok y pegá la URL.
# PUBLIC_API_URL=https://tu-tunel.ngrok-free.app

# Verificación de identidad del alta de chofer. Por defecto: PDF417 + cruce de
# datos + selfie (Tier 1). Los enforcement quedan apagados para no romper Expo
# Go / web; activalos solo cuando tengas el dev build (liveness) o el runtime
# de face-api (match facial). Ver "Verificación de identidad" en el README.
# LIVENESS_REQUERIDO=false      # true: exige la prueba de vida (Tier 2, dev build)
# FACE_MATCH_REQUERIDO=false    # true: exige coincidencia selfie↔DNI (Tier 3)
# FACE_MODELS_DIR=              # ruta a los pesos de face-api (default: backend/models)
